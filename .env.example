# Nova 环境配置示例 —— 复制为 .env 并填入真实值
# ⚠️ 切勿把真实密钥提交到仓库（本仓库为 public，.env 已被 .gitignore 忽略）

# ── 主力模型：DeepSeek（OpenAI 兼容协议）──
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 复杂推理 / 决策默认用 deepseek-v4-pro；快速/低成本任务用 deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL_FAST=deepseek-v4-flash

# ── 可选：快速/低成本模型与容灾（暂可留空，仅用 DeepSeek 时不需要）──
# MINIMAX_API_KEY=
# QWEN_API_KEY=
# QWENVL_API_KEY=        # 视觉 OCR

# ── 可选：出站网络代理 ──
# HTTPS_PROXY=
# ALL_PROXY=socks5://127.0.0.1:7890
